# =========================
# 服务端基础配置
# =========================

# 应用服务端口，默认可用 3000
PORT=3000

# JWT 签名密钥
# 必填：登录态鉴权会用到
# 生产环境务必替换成高强度随机字符串
JWTKEY=replace-with-a-strong-random-secret


# =========================
# 数据库配置
# =========================

# PostgreSQL 连接串
# 必填：Drizzle、后端服务、数据库检查脚本都会读取它
# 示例：
# postgresql://username:password@host:6543/postgres
DATABASE_URL=postgresql://username:password@host:6543/postgres


# =========================
# Qwen / DashScope 配置
# =========================

# Qwen 兼容接口地址
# 可选：不填时默认使用阿里云 DashScope 兼容地址
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Qwen API Key
# 必填（做章节分析时必须有）
QWEN_API_KEY=

# Qwen 模型名
# 可选：不填时默认 qwen-plus
QWEN_MODEL=qwen-plus

# 单次请求超时时间，单位毫秒
# 可选：默认 120000
QWEN_TIMEOUT_MS=120000

# 请求失败后的最大重试次数
# 可选：默认 1
QWEN_MAX_RETRIES=1

# 模型温度参数
# 可选：默认 0.2，越低越稳定
QWEN_TEMPERATURE=0.2

# 如果你更习惯使用 DashScope 命名，也可以配这一组
# 代码里会优先读取 QWEN_API_KEY / QWEN_API_URL，
# 如果没配，再回退读取 DASHSCOPE_API_KEY / DASHSCOPE_API_URL
DASHSCOPE_API_URL=
DASHSCOPE_API_KEY=


# =========================
# 前端 / Vite 配置
# =========================

# Supabase 项目地址
# 前端示例页和部分 Supabase 客户端逻辑会读取
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 前端 publishable key
# 推荐填写这个字段
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# 兼容旧写法的 anon key
# 可选：如果你已经配了 VITE_SUPABASE_PUBLISHABLE_KEY，可以不填
VITE_SUPABASE_ANON_KEY=
